# ==========================================
# Backend Server Example Configuration
# ==========================================

# --- Database ---
DATABASE_URL="postgresql://<db_user>:<db_password>@localhost:5432/<db_name>?schema=public"

# --- JWT ---
JWT_SECRET="CHANGE_ME_TO_A_STRONG_SECRET"
JWT_EXPIRES_IN="7d"

# --- Email (Resend) ---
RESEND_API_KEY="re_CHANGE_ME"
EMAIL_FROM_NAME="JP DK"
EMAIL_FROM_ADDRESS="noreply@jpdk.cl"

#--- Frontend & Revalidation ---
FRONTEND_URL="http://localhost:3000"
STOREFRONT_REVALIDATE_URL="http://localhost:3000/api/revalidate"
STOREFRONT_REVALIDATE_SECRET="CHANGE_ME"

# --- Internal API Key ---
INTERNAL_API_KEY="CHANGE_ME_internal_api_key_for_n8n"

# --- CORS ---
CORS_ORIGINS="http://localhost:3000"

# --- Server ---
PORT=5001
NODE_ENV="development"