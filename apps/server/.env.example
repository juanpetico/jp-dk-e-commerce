# ==========================================
# Backend Server — Example Configuration
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees el .env con secrets reales.
# ==========================================

# --- Database ---
# Dev local:    postgresql://ecommerce_user:ecommerce_password@localhost:5432/ecommerce_db
# Producción:   URL de Supabase (pooler) en Vercel
DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<db>"
# Opcional: URL dedicada para comandos Prisma (fallback si no existe usa DATABASE_URL)
PRISMA_DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<db>"
# Opcional: URL local para migraciones en desarrollo
DATABASE_URL_LOCAL="postgresql://ecommerce_user:ecommerce_password@localhost:5432/ecommerce_db"
# Comandos útiles:
# - Producción/Staging: pnpm --filter @repo/server migrate:deploy
# - Local:              pnpm --filter @repo/server migrate:deploy:local

# --- JWT ---
JWT_SECRET="CHANGE_ME_min_32_chars"
JWT_EXPIRES_IN="7d"

# --- Email (Resend) ---
RESEND_API_KEY="re_CHANGE_ME"
EMAIL_FROM_NAME="JP DK"
EMAIL_FROM_ADDRESS="noreply@jpdk.cl"

# --- Frontend & Revalidation ---
# Dev local:    http://localhost:3000
# Producción:   URL de Vercel
FRONTEND_URL="http://localhost:3000"
STOREFRONT_REVALIDATE_URL="http://localhost:3000/api/revalidate"
STOREFRONT_REVALIDATE_SECRET="CHANGE_ME_min_32_chars"

# --- Internal API Key (debe coincidir con .env raíz para n8n) ---
INTERNAL_API_KEY="CHANGE_ME_internal_api_key_for_n8n"

# --- CORS (separado por comas) ---
# Dev local:    http://localhost:3000
# Producción:   URL de Vercel (producción + custom domain si aplica)
CORS_ORIGINS="http://localhost:3000"
# Sufijo para aceptar previews de Vercel (ej: "juanpeticos-projects.vercel.app")
CORS_VERCEL_SUFFIX=""

# --- Server ---
PORT=5001
NODE_ENV="development"
