generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Address {
  id                                     String   @id
  name                                   String
  rut                                    String?
  street                                 String
  comuna                                 String
  region                                 String
  zipCode                                String?
  country                                String   @default("Chile")
  phone                                  String
  isDefault                              Boolean  @default(false)
  isActive                               Boolean  @default(true)
  userId                                 String
  createdAt                              DateTime @default(now())
  updatedAt                              DateTime
  company                                String?
  User                                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Order_Order_billingAddressIdToAddress  Order[]  @relation("Order_billingAddressIdToAddress")
  Order_Order_shippingAddressIdToAddress Order[]  @relation("Order_shippingAddressIdToAddress")

  @@index([userId])
}

model Cart {
  id        String     @id
  userId    String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime
  User      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  CartItem  CartItem[]
}

model CartItem {
  id        String   @id
  cartId    String
  productId String
  quantity  Int      @default(1)
  size      Size
  createdAt DateTime @default(now())
  updatedAt DateTime
  Cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  Product   Product  @relation(fields: [productId], references: [id])

  @@unique([cartId, productId, size])
}

model Category {
  id      String    @id
  name    String    @unique
  slug    String    @unique
  Product Product[]
}

model Coupon {
  id             String       @id
  code           String       @unique
  description    String?
  type           DiscountType
  value          Int
  minAmount      Int          @default(0)
  maxUses        Int?
  usedCount      Int          @default(0)
  maxUsesPerUser Int          @default(1)
  startDate      DateTime     @default(now())
  endDate        DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  isPublic       Boolean      @default(true)
  Order          Order[]
  UserCoupon     UserCoupon[]
}

model Order {
  id                                       String      @id
  date                                     String
  total                                    Int
  subtotal                                 Int
  shippingCost                             Int
  taxes                                    Int
  taxRate                                  Float
  shippingMethod                           String?
  status                                   OrderStatus @default(PENDING)
  isPaid                                   Boolean     @default(false)
  paidAt                                   DateTime?
  confirmedAt                              DateTime?
  userId                                   String
  shippingAddressId                        String
  billingAddressId                         String
  customerName                             String?
  customerEmail                            String?
  customerPhone                            String?
  shippingName                             String?
  shippingRut                              String?
  shippingStreet                           String?
  shippingComuna                           String?
  shippingRegion                           String?
  shippingZipCode                          String?
  shippingPhone                            String?
  billingName                              String?
  billingRut                               String?
  billingStreet                            String?
  billingComuna                            String?
  billingRegion                            String?
  billingZipCode                           String?
  billingPhone                             String?
  createdAt                                DateTime    @default(now())
  updatedAt                                DateTime
  billingCompany                           String?
  couponId                                 String?
  discountAmount                           Int         @default(0)
  Address_Order_billingAddressIdToAddress  Address     @relation("Order_billingAddressIdToAddress", fields: [billingAddressId], references: [id])
  Coupon                                   Coupon?     @relation(fields: [couponId], references: [id])
  Address_Order_shippingAddressIdToAddress Address     @relation("Order_shippingAddressIdToAddress", fields: [shippingAddressId], references: [id])
  User                                     User        @relation(fields: [userId], references: [id])
  OrderItem                                OrderItem[]

  @@index([userId])
}

model OrderItem {
  id        String  @id
  quantity  Int
  price     Int
  size      Size
  orderId   String
  productId String
  Order     Order   @relation(fields: [orderId], references: [id])
  Product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Product {
  id              String           @id
  name            String
  description     String?
  price           Int
  originalPrice   Int?
  discountPercent Int?
  isNew           Boolean          @default(true)
  isSale          Boolean          @default(false)
  slug            String           @unique
  isPublished     Boolean          @default(false)
  categoryId      String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime
  CartItem        CartItem[]
  OrderItem       OrderItem[]
  Category        Category         @relation(fields: [categoryId], references: [id])
  ProductImage    ProductImage[]
  ProductVariant  ProductVariant[]

  @@index([categoryId])
  @@index([slug])
}

model ProductImage {
  id        String  @id
  url       String
  productId String
  Product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String  @id
  size      Size
  stock     Int     @default(0)
  productId String
  Product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
}

model StoreConfig {
  id String @id @default("default")

  // Módulo de Recompensas (Fidelización)
  welcomeCouponCode String @default("BIENVENIDA")
  vipThreshold      Int    @default(100000)
  vipCouponCode     String @default("VIP_GANG")
  vipRewardMessage  String @default("¡Felicidades! Por tu compra sobre $100.000 has ganado un 15% de descuento.")

  // Módulo de Logística (Chile)
  freeShippingThreshold Int @default(50000)
  baseShippingCost      Int @default(3500)

  // Reglas de Negocio y Alertas
  defaultTaxRate    Float @default(0.19) // IVA Chile
  lowStockThreshold Int   @default(5)

  // Branding e Identidad
  storeName       String  @default("JP DK")
  supportEmail    String  @default("soporte@jpdk.cl")
  maintenanceMode Boolean @default(false)

  updatedAt DateTime @updatedAt
}

model User {
  id         String       @id
  name       String?
  email      String       @unique
  password   String
  phone      String?
  role       Role         @default(CLIENT)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime
  Address    Address[]
  Cart       Cart?
  Order      Order[]
  UserCoupon UserCoupon[]
}

model UserCoupon {
  id         String    @id
  userId     String
  couponId   String
  isUsed     Boolean   @default(false)
  usedAt     DateTime?
  assignedAt DateTime  @default(now())
  Coupon     Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  User       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, couponId])
  @@index([couponId])
  @@index([userId])
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum Role {
  CLIENT
  ADMIN
  SUPERADMIN
}

enum Size {
  S
  M
  L
  XL
  XXL
  STD
}
