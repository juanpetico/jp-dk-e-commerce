// Configuración básica
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Usuarios y Roles
enum Role {
  CLIENT
  ADMIN
  SUPERADMIN
}

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  password  String
  phone     String?
  role      Role      @default(CLIENT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  orders    Order[]
  addresses Address[]
  cart      Cart?
}

// 1.1. Direcciones del Usuario
model Address {
  id        String  @id @default(cuid())
  name      String
  rut       String?
  street    String
  comuna    String
  region    String
  zipCode   String? // Código postal
  country   String  @default("Chile")
  phone     String
  isDefault Boolean @default(false)
  isActive  Boolean @default(true) // Para soft delete y mantener historial en órdenes

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relaciones inversa para Orders
  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// 2. Productos y Categorías
enum Size {
  S
  M
  L
  XL
  XXL
  STD // Talla estándar para lentes y accesorios
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique // Para URLs amigables (ej: /category/poleras)
  products Product[]
}

model Product {
  id              String  @id @default(cuid())
  name            String
  description     String?
  price           Int // Usamos Int para evitar problemas de redondeo (ej: 25990)
  originalPrice   Int? // Precio original (para ofertas)
  discountPercent Int? // Porcentaje de descuento (ej: 20 para 20%)
  isNew           Boolean @default(true)
  isSale          Boolean @default(false)
  slug            String  @unique // SEO: /product/polera-shooters-pink-black
  isPublished     Boolean @default(false)

  // Relaciones
  categoryId String
  category   Category         @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  variants   ProductVariant[]
  orderItems OrderItem[]
  cartItems  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([slug])
}

model ProductVariant {
  id    String @id @default(cuid())
  size  Size
  stock Int    @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Asegura que no existan duplicados de la misma talla para un producto
  @@unique([productId, size])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// 3. Sistema de Órdenes (Ventas Reales)
enum OrderStatus {
  PENDING // Pendiente
  CONFIRMED // Confirmado (equivalente a PAID)
  SHIPPED // Enviado
  DELIVERED // Entregado
  CANCELLED // Cancelado
}

model Order {
  id             String      @id @default(cuid())
  date           String // Fecha formato string para frontend
  total          Int
  subtotal       Int // Subtotal antes de impuestos y envío
  shippingCost   Int // Costo de envío
  taxes          Int // Impuestos aplicados
  taxRate        Float // Tasa de impuesto (ej: 0.19 para 19%)
  shippingMethod String? // Descripción del método de envío
  status         OrderStatus @default(PENDING)
  isPaid         Boolean     @default(false)
  paidAt         DateTime?
  confirmedAt    DateTime? // Fecha de confirmación

  // Relación con el cliente
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Direcciones (Relaciones Históricas - Mantener por compatibilidad o integridad referencial)
  shippingAddressId String
  shippingAddress   Address @relation("ShippingAddress", fields: [shippingAddressId], references: [id])

  billingAddressId String
  billingAddress   Address @relation("BillingAddress", fields: [billingAddressId], references: [id])

  // Snapshot de Cliente
  customerName  String?
  customerEmail String?
  customerPhone String?

  // Snapshot de Dirección de Envío/Despacho
  shippingName    String?
  shippingRut     String?
  shippingStreet  String?
  shippingComuna  String?
  shippingRegion  String?
  shippingZipCode String?
  shippingPhone   String?

  // Snapshot de Dirección de Facturación
  billingName    String?
  billingRut     String?
  billingStreet  String?
  billingComuna  String?
  billingRegion  String?
  billingZipCode String?
  billingPhone   String?

  // Detalle de la compra
  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model OrderItem {
  id       String @id @default(cuid())
  quantity Int
  price    Int // Guardamos el precio del momento de la compra
  size     Size

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// 4. Carrito de Compras
model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique // Opcional para permitir carritos de invitados si se desea
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  size      Size
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Evita duplicados: si se agrega el mismo producto y talla, se actualiza la cantidad
  @@unique([cartId, productId, size])
}
