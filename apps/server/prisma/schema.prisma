generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Address {
  id             String   @id @default(cuid())
  name           String
  rut            String?
  street         String
  comuna         String
  region         String
  zipCode        String?
  country        String   @default("Chile")
  phone          String
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingOrders  Order[]  @relation("BillingAddress")
  shippingOrders Order[]  @relation("ShippingAddress")

  @@index([userId])
}

model Cart {
  id               String     @id @default(cuid())
  userId           String?    @unique
  reminderSentAt   DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  user             User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items            CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  size      Size
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([cartId, productId, size])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  imageUrl    String?
  isPublished Boolean   @default(true)
  sortOrder   Int       @default(0)
  products    Product[]

  @@index([isPublished])
}

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  description    String?
  type           DiscountType
  value          Int
  minAmount      Int          @default(0)
  maxUses        Int?
  usedCount      Int          @default(0)
  maxUsesPerUser Int          @default(1)
  startDate      DateTime     @default(now())
  endDate        DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  isPublic       Boolean      @default(true)
  orders         Order[]
  userCoupons    UserCoupon[]
}

model Order {
  id                String      @id @default(cuid())
  date              DateTime    @default(now())
  total             Int
  subtotal          Int
  shippingCost      Int
  taxes             Int
  taxRate           Float
  shippingMethod    String?
  status            OrderStatus @default(PENDING)
  isPaid            Boolean     @default(false)
  paidAt            DateTime?
  confirmedAt       DateTime?
  userId            String
  shippingAddressId String
  billingAddressId  String
  customerName      String?
  customerEmail     String?
  customerPhone     String?
  shippingName      String?
  shippingRut       String?
  shippingStreet    String?
  shippingComuna    String?
  shippingRegion    String?
  shippingZipCode   String?
  shippingPhone     String?
  billingName       String?
  billingRut        String?
  billingStreet     String?
  billingComuna     String?
  billingRegion     String?
  billingZipCode    String?
  billingPhone      String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  billingCompany    String?
  couponId          String?
  discountAmount    Int         @default(0)
  reviewRequestedAt DateTime?
  billingAddress    Address     @relation("BillingAddress", fields: [billingAddressId], references: [id])
  coupon            Coupon?     @relation(fields: [couponId], references: [id])
  shippingAddress   Address     @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  user              User        @relation(fields: [userId], references: [id])
  items             OrderItem[]

  @@index([userId])
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Int
  size      Size
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Product {
  id              String           @id @default(cuid())
  name            String
  description     String?
  price           Int
  originalPrice   Int?
  discountPercent Int?
  isNew           Boolean          @default(true)
  isSale          Boolean          @default(false)
  slug            String           @unique
  isPublished     Boolean          @default(false)
  categoryId      String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  cartItems       CartItem[]
  orderItems      OrderItem[]
  category        Category         @relation(fields: [categoryId], references: [id])
  images          ProductImage[]
  variants        ProductVariant[]

  @@index([categoryId])
  @@index([slug])
  @@index([isPublished])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String  @id @default(cuid())
  size      Size
  stock     Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
}

model StoreConfig {
  id String @id @default("default")

  // Módulo de Recompensas (Fidelización)
  welcomeCouponCode  String       @default("BIENVENIDA")
  welcomeCouponType  DiscountType @default(PERCENTAGE)
  welcomeCouponValue Int          @default(10)
  vipThreshold       Int          @default(100000)
  vipCouponCode      String       @default("VIP_GANG")
  vipCouponType      DiscountType @default(PERCENTAGE)
  vipCouponValue     Int          @default(15)
  vipRewardMessage   String       @default("¡Felicidades! Por tu compra sobre $100.000 has ganado un 15% de descuento.")

  // Módulo de Logística (Chile)
  freeShippingThreshold Int @default(50000)
  baseShippingCost      Int @default(3500)

  // Reglas de Negocio y Alertas
  defaultTaxRate    Float @default(0.19) // IVA Chile
  lowStockThreshold Int   @default(5)

  // Branding e Identidad
  storeName       String  @default("JP DK")
  supportEmail    String  @default("soporte@jpdk.cl")
  maintenanceMode Boolean @default(false)

  updatedAt DateTime @updatedAt
}

model User {
  id                 String       @id @default(cuid())
  name               String?
  email              String       @unique
  password           String
  phone              String?
  role               Role         @default(CLIENT)
  isActive             Boolean      @default(true)
  deactivationReason   String?
  lastLogin            DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  addresses          Address[]
  cart               Cart?
  orders             Order[]
  userCoupons        UserCoupon[]
  auditLogsAsActor   AuditLog[]   @relation("AuditActor")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  actorId    String
  oldValue   String?
  newValue   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User     @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model UserCoupon {
  id         String    @id @default(cuid())
  userId     String
  couponId   String
  isUsed     Boolean   @default(false)
  usedAt     DateTime?
  assignedAt DateTime  @default(now())
  coupon     Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, couponId])
  @@index([couponId])
  @@index([userId])
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
}

enum Role {
  CLIENT
  ADMIN
  SUPERADMIN
}

enum Size {
  S
  M
  L
  XL
  XXL
  STD
}
