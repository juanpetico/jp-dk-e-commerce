# ==========================================
# Frontend Web — Example Configuration
# Copia este archivo como .env.local y completa los valores reales.
# NUNCA commitees el .env.local con secrets reales.
# ==========================================

# --- API ---
# Dev local:    http://localhost:5001/api
# Producción:   URL pública del backend en Vercel (ecommerce-api-dun.vercel.app/api)
NEXT_PUBLIC_API_URL=http://localhost:5001/api

# --- Revalidation (debe coincidir con STOREFRONT_REVALIDATE_SECRET del backend) ---
REVALIDATE_SECRET=CHANGE_ME_min_32_chars
