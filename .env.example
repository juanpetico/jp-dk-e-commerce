# Variables para docker-compose (servicio n8n)
# Copia este archivo a .env y ajusta los valores.

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123
# Cambia esto antes de cargar credenciales en n8n. Si cambia, las credenciales previamente
# guardadas no se pueden desencriptar.
N8N_ENCRYPTION_KEY=dev-encryption-key-change-me

# --- Automation bridge ---
# Debe coincidir con el INTERNAL_API_KEY del backend (apps/server/.env).
INTERNAL_API_KEY=dev-internal-api-key-change-me
