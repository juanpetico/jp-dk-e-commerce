# ==========================================
# Raíz — Example Configuration (n8n & Automation)
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees el .env con secrets reales.
# ==========================================

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME
# IMPORTANTE: si cambias esta clave después de guardar credenciales en n8n,
# las credenciales existentes no podrán desencriptarse.
N8N_ENCRYPTION_KEY=CHANGE_ME_min_32_chars

# --- Automation bridge (debe coincidir con INTERNAL_API_KEY del backend) ---
INTERNAL_API_KEY=CHANGE_ME_internal_api_key_for_n8n
