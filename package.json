{
  "name": "PROYECTO E-COMMERCE",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "pnpm --filter server exec prisma generate",
    "db:push": "pnpm --filter server exec prisma db push",
    "db:migrate": "pnpm --filter server exec prisma migrate dev",
    "db:studio": "pnpm --filter server exec prisma studio"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.1",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}